{
	"name": "@yaos-git/mesh-sync",
	"version": "226.0.0",
	"description": "Keep files in sync across repositories with real-time transformations",
	"main": "dist/cli.js",
	"bin": {
		"mesh-sync": "dist/cli.js",
		"mesh-sync-tui": "dist/tui.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "run-tui -r \"^dev:\"",
		"dev:typescript": "tsgo --watch --noEmit -p tsconfig.app.json",
		"dev:test": "vitest --watch",
		"build": "node esbuild.config.js",
		"lint": "npm run lint:types && npm run lint:fix && npm run lint:format && npm run lint:audit",
		"lint:check": "biome lint .",
		"lint:fix": "biome check . --write",
		"lint:format": "biome format . --write",
		"lint:types": "tsgo --noEmit -p tsconfig.app.json",
		"lint:audit": "npm audit",
		"test": "npm run test:unit && npm run test:types && npm run test:e2e",
		"test:unit": "vitest run -c vitest.unit.config.ts",
		"test:types": "vitest run -c vitest.type.config.ts",
		"test:e2e": "npm run build && vitest run -c vitest.e2e.config.ts",
		"coverage": "vitest run --coverage",
		"coverage:unit": "vitest run --coverage -c vitest.unit.config.ts",
		"coverage:types": "vitest run --coverage -c vitest.type.config.ts",
		"size": "size-limit",
		"prepublishOnly": "npm run lint:types && npm run lint:check && npm run test:unit && npm run test:types && npm run test:e2e && npm run lint:audit && npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/YAOSGit/mesh-sync.git"
	},
	"bugs": {
		"url": "https://github.com/YAOSGit/mesh-sync/issues"
	},
	"homepage": "https://github.com/YAOSGit/mesh-sync#readme",
	"keywords": [
		"cli",
		"sync",
		"transformer",
		"codegen",
		"devtools"
	],
	"author": {
		"name": "Ygor de Paula",
		"email": "ygorh.de.paula@gmail.com",
		"url": "https://github.com/YAOSGit/mesh-sync"
	},
	"license": "ISC",
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"dependencies": {
		"@yaos-git/toolkit": "0.0.26-3-19a",
		"chalk": "^5.6.2",
		"chokidar": "^5.0.0",
		"commander": "^14.0.3",
		"esbuild": "^0.27.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@size-limit/file": "^11.2.0",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.7",
		"@typescript/native-preview": "^7.0.0-dev.20251216",
		"@vitest/coverage-v8": "^4.1.0",
		"@yaos-git/run-tui": "^126.0.0",
		"ink": "^6.8.0",
		"jsdom": "^27.3.0",
		"node-pty": "^1.0.0",
		"size-limit": "^11.2.0",
		"react": "^19.2.4",
		"strip-ansi": "^7.1.2",
		"vitest": "^4.1.0"
	}
}
