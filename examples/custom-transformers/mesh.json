{
	"syncs": [
		{
			"id": "vendor-types",
			"source": "./sources/shared-types.ts",
			"transformer": [
				"strip-comments",
				"./transformers/strip-internal.ts",
				"./transformers/add-namespace.ts"
			],
			"target": "./generated/vendor-types.ts",
			"strategy": { "manual": true }
		},
		{
			"id": "api-client",
			"source": "./sources/api-spec.json",
			"transformer": "openapi-to-fetch",
			"target": "./generated/api-client.ts",
			"strategy": { "manual": true }
		},
		{
			"id": "env-config",
			"source": "./sources/env-template.env",
			"transformer": ["env-filter", "env-to-ts"],
			"target": "./generated/env-config.ts",
			"strategy": { "manual": true }
		}
	]
}
